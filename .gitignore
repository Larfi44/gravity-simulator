```gitignore
# TypeScript/JavaScript build artifacts
*.js.map
*.tsbuildinfo
dist/
build/

# Dependencies
node_modules/

# Logs and temp files
*.log
*.tmp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
*.coverage

# Python related (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
.coverage.*
.cache
.pytest_cache/
.mypy_cache/

# Build outputs
target/
build/
dist/
out/
temp/
tmp/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```
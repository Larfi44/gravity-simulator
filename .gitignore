```gitignore
# Compiled and build artifacts
*.js
*.ts

# Dependencies
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# Environment
.env
.env.local
.env.*

# Coverage reports
coverage/
htmlcov/
*.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.nox/

# Build outputs
dist/
build/
*.egg-info/
.eggs/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```